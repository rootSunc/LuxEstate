{
  "name": "luxestate",
  "version": "1.0.0",
  "description": "Production-minded real estate marketplace demo built with React, Express, and MongoDB.",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon api/index.js",
    "start": "node api/index.js",
    "dev:frontend": "npm run dev --prefix frontend",
    "lint": "npm run lint:api && npm run lint:frontend",
    "lint:api": "eslint api --report-unused-disable-directives --max-warnings 0",
    "lint:frontend": "npm run lint --prefix frontend",
    "build": "npm run build --prefix frontend",
    "test": "vitest run",
    "verify": "npm audit --audit-level=moderate && npm run lint:api && npm test && npm audit --audit-level=moderate --prefix frontend && npm run lint --prefix frontend && npm run build --prefix frontend",
    "db:init": "node api/scripts/init-db.js",
    "db:reset": "node api/scripts/init-db.js --reset"
  },
  "keywords": [
    "real-estate",
    "marketplace",
    "mern",
    "react",
    "express",
    "mongodb"
  ],
  "author": "LuxEstate contributors",
  "license": "ISC",
  "engines": {
    "node": ">=20.20.0"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.6.1",
    "express": "^4.22.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "nodemon": "^3.1.0",
    "vitest": "^4.1.6"
  }
}
